# ===== Autonomous-PR-Reviewer 环境变量示例 =====
# 复制本文件为 .env 并填入真实值；.env 不要提交到 git。

# GitHub Personal Access Token，用于读取 PR 与发布评论
# 生成地址：https://github.com/settings/tokens （建议 fine-grained，授予目标仓库 Pull requests 读写权限）
GITHUB_TOKEN=

# 模型厂商路由：openai / anthropic。留空则按 LLM_MODEL 自动推断（claude* → anthropic，其余 → openai 兼容）。
LLM_PROVIDER=

# 大语言模型 API Key（OpenAI 兼容厂商：DeepSeek / OpenAI / Gemini 等）
LLM_API_KEY=

# LLM 接口地址（OpenAI 兼容端点）。留空则默认 DeepSeek。仅 openai 兼容后端使用。
#   DeepSeek: https://api.deepseek.com
#   OpenAI:   https://api.openai.com/v1
#   Gemini:   https://generativelanguage.googleapis.com/v1beta/openai/
LLM_BASE_URL=

# 模型 ID（按厂商填写）。留空则默认 deepseek-chat（anthropic 默认 claude-sonnet-4-6）。
#   例如：deepseek-chat / gpt-4o / gemini-2.5-flash / claude-sonnet-4-6
#   注意：Gemini 免费层仅 Flash 系列有配额，Pro 系列需开通 billing。
LLM_MODEL=

# Anthropic（Claude）专用 API Key；仅当 provider=anthropic 时需要（缺省回退 LLM_API_KEY）。
ANTHROPIC_API_KEY=
